page {
  min-height: 100%;
  background: #f5f6f2;
  color: #13221c;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  line-height: 1.5;
}

button,
input {
  font: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
}

.brand-mark {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #13221c;
  color: #d7f55f;
  font-family: "Songti SC", STSong, serif;
  font-size: 36rpx;
  font-weight: 700;
}

.step-label {
  color: #415149;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.mono-data {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-variant-numeric: tabular-nums;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
