<view class="page-shell calculator-page">
  <view class="intro-panel">
    <view class="brand-row">
      <view class="brand-lockup" aria-label="真涨薪">
        <view class="brand-mark" aria-hidden="true">真</view>
        <text class="brand-name">真涨薪</text>
      </view>
      <view class="privacy-badge">本地计算 · 不上传薪资</view>
    </view>

    <view class="intro-copy">
      <text class="step-label">第 1 步 · 输入条件</text>
      <view class="page-title" role="heading" aria-level="1">
        <text>把账面条件</text>
        <text>摆在一起</text>
      </view>
      <text class="page-lead">每份工作只填 5 项。我们会把发薪月数、保证奖金、工作和通勤时间放在同一张账上。</text>
      <button class="text-button" bindtap="fillExample" hover-class="text-button-active" aria-label="填入完整示例数据">填入示例看看</button>
    </view>
  </view>

  <view wx:if="{{generalError}}" class="form-alert" role="alert" aria-live="assertive">
    <text class="form-alert-title">请检查输入</text>
    <text>{{generalError}}</text>
  </view>

  <view class="jobs-list">
    <view
      wx:for="{{viewJobs}}"
      wx:key="id"
      wx:for-item="job"
      class="job-panel job-{{job.id}}"
      aria-labelledby="job-title-{{job.id}}"
    >
      <view class="job-header">
        <view class="job-title-group">
          <text class="job-index mono-data">{{job.displayIndex}}</text>
          <text id="job-title-{{job.id}}" class="job-title">{{job.title}}</text>
        </view>
        <button
          wx:if="{{job.id === 'offerB'}}"
          class="remove-button"
          bindtap="removeOfferB"
          hover-class="remove-button-active"
          aria-label="移除 Offer B，可在 5 秒内撤销"
        >移除</button>
      </view>

      <view class="field-list">
        <view
          wx:for="{{job.fields}}"
          wx:key="key"
          wx:for-item="field"
          id="field-{{job.id}}-{{field.key}}"
          class="field-block {{field.error ? 'field-block-error' : ''}}"
        >
          <view class="field-main">
            <label class="field-label" for="input-{{job.id}}-{{field.key}}">{{field.label}}</label>
            <view class="input-wrap">
              <input
                id="input-{{job.id}}-{{field.key}}"
                class="field-input mono-data"
                type="digit"
                inputmode="decimal"
                value="{{field.value}}"
                placeholder="{{field.placeholder}}"
                placeholder-style="color:#415149"
                maxlength="16"
                cursor-spacing="128"
                data-job-id="{{job.id}}"
                data-key="{{field.key}}"
                bindinput="onInput"
                bindblur="onBlur"
                aria-label="{{job.title}}{{field.label}}，单位{{field.suffix}}"
                aria-invalid="{{field.error ? 'true' : 'false'}}"
                aria-describedby="{{field.error ? 'error-' + job.id + '-' + field.key : ''}}"
              />
              <text class="field-suffix">{{field.suffix}}</text>
            </view>
          </view>
          <text
            wx:if="{{field.error}}"
            id="error-{{job.id}}-{{field.key}}"
            class="field-error"
            role="alert"
          >{{field.error}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{undoOfferVisible}}" class="undo-banner" role="status" aria-live="polite">
    <text>已移除 Offer B</text>
    <button class="undo-button" bindtap="undoRemoveOffer" hover-class="undo-button-active">撤销</button>
  </view>

  <button
    wx:if="{{!hasOfferB}}"
    class="add-offer-button"
    bindtap="addOfferB"
    hover-class="add-offer-button-active"
  >＋ 添加 Offer B</button>

  <view class="input-note">
    <text class="input-note-title">怎么填固定收入？</text>
    <text>例如 13 薪、另有 1 个月保证奖金，分别填写 13 和 1；没有保证奖金或通勤时填写 0。</text>
  </view>

  <view class="assumptions" aria-label="计算口径">
    <view class="assumptions-header">
      <text class="assumptions-title">计算口径</text>
      <text class="assumptions-tag">税前估算</text>
    </view>
    <view class="assumption-row">
      <text>每年工作</text>
      <text class="mono-data">48 周</text>
    </view>
    <view class="assumption-row">
      <text>每年通勤</text>
      <text class="mono-data">240 天 · 往返</text>
    </view>
    <text class="assumption-help">暂不计个税、五险一金、试用期折扣、浮动奖金、股票和期权。</text>
  </view>

  <button class="clear-button" bindtap="clearLocalData" hover-class="clear-button-active">清除本机数据</button>

  <view class="submit-bar">
    <view class="submit-bar-inner">
      <view class="submit-summary">
        <text class="submit-count mono-data">{{optionCount}} 个选项</text>
        <text>草稿自动保存在本机</text>
      </view>
      <button
        class="submit-button"
        bindtap="calculate"
        hover-class="submit-button-active"
        loading="{{isSubmitting}}"
        disabled="{{isSubmitting}}"
        aria-busy="{{isSubmitting ? 'true' : 'false'}}"
      >{{isSubmitting ? '正在计算' : '算清真实涨幅'}}<text wx:if="{{!isSubmitting}}" aria-hidden="true">→</text></button>
    </view>
  </view>
</view>
