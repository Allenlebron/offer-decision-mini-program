<view class="page-shell calculator-page">
  <view class="page-toolbar">
    <view class="local-badge" aria-label="薪资数据保存在本机，不会上传">
      <text>本机保存 · 不上传</text>
    </view>
    <button class="example-button" bindtap="fillExample" hover-class="text-button-active">填入示例</button>
  </view>

  <view class="job-switcher" aria-label="切换工作选项">
    <button
      wx:for="{{viewJobs}}"
      wx:key="id"
      wx:for-item="job"
      class="job-tab {{job.selected ? 'job-tab-selected' : ''}}"
      data-index="{{job.index}}"
      bindtap="switchJob"
      hover-class="job-tab-active"
      aria-pressed="{{job.selected ? 'true' : 'false'}}"
    >
      <text>{{job.title}}</text>
      <text wx:if="{{job.isComplete}}" class="job-tab-check" aria-label="已填写">✓</text>
      <text wx:else class="job-tab-count mono-data">{{job.filledCount}}/5</text>
    </button>
    <button
      wx:if="{{!hasOfferB}}"
      class="job-tab add-job-tab"
      bindtap="addOfferB"
      hover-class="job-tab-active"
      aria-label="添加 Offer B"
    >+ Offer B</button>
  </view>

  <view wx:if="{{activeJob}}" class="entry-note">
    <view class="info-mark" aria-hidden="true">i</view>
    <text>{{activeJob.id === 'current' ? '只填确定会拿到的钱，按实际时间估算。' : activeDescription}}</text>
    <button
      wx:if="{{activeJob.id === 'offerB'}}"
      class="remove-button"
      bindtap="removeOfferB"
      hover-class="remove-button-active"
    >移除</button>
  </view>

  <view wx:if="{{generalError}}" class="form-alert" role="alert" aria-live="assertive">
    <text class="form-alert-title">请检查输入</text>
    <text>{{generalError}}</text>
  </view>

  <view wx:if="{{activeJob}}" class="form-workspace" aria-label="{{activeJob.title}}">
    <view class="field-group">
      <view class="group-title">
        <text>固定收入</text>
      </view>
      <view class="field-card">
        <view
          wx:for="{{activeIncomeFields}}"
          wx:key="key"
          wx:for-item="field"
          id="field-{{activeJob.id}}-{{field.key}}"
          class="field-row {{field.error ? 'field-row-error' : ''}}"
        >
          <view class="field-main">
            <view class="field-copy">
              <label class="field-label" for="input-{{activeJob.id}}-{{field.key}}">{{field.label}}</label>
              <text class="field-hint">{{field.hint}}</text>
            </view>
            <view class="field-control">
              <text wx:if="{{field.key === 'monthlySalary' && field.value}}" class="field-prefix">¥</text>
              <input
                id="input-{{activeJob.id}}-{{field.key}}"
                class="field-input mono-data {{field.key === 'monthlySalary' ? 'field-input-salary' : ''}}"
                type="digit"
                inputmode="decimal"
                value="{{field.value}}"
                placeholder="{{field.placeholder}}"
                placeholder-style="color:#66748A;font-weight:500"
                maxlength="16"
                cursor-spacing="250"
                data-job-id="{{activeJob.id}}"
                data-key="{{field.key}}"
                bindinput="onInput"
                bindblur="onBlur"
                aria-label="{{activeJob.title}}{{field.label}}，单位{{field.suffix}}"
                aria-invalid="{{field.error ? 'true' : 'false'}}"
                aria-describedby="{{field.error ? 'error-' + activeJob.id + '-' + field.key : ''}}"
              />
              <text wx:if="{{field.key !== 'monthlySalary'}}" class="field-suffix">{{field.suffix}}</text>
              <button
                wx:if="{{field.value}}"
                class="clear-field-button"
                data-job-id="{{activeJob.id}}"
                data-key="{{field.key}}"
                bindtap="clearField"
                hover-class="clear-field-button-active"
                aria-label="清除{{field.label}}"
              >×</button>
            </view>
          </view>
          <text
            wx:if="{{field.error}}"
            id="error-{{activeJob.id}}-{{field.key}}"
            class="field-error"
            role="alert"
          >{{field.error}}</text>
        </view>
      </view>
    </view>

    <view class="field-group">
      <view class="group-title">
        <text>时间成本</text>
      </view>
      <view class="field-card">
        <view
          wx:for="{{activeTimeFields}}"
          wx:key="key"
          wx:for-item="field"
          id="field-{{activeJob.id}}-{{field.key}}"
          class="field-row {{field.error ? 'field-row-error' : ''}}"
        >
          <view class="field-main">
            <view class="field-copy">
              <label class="field-label" for="input-{{activeJob.id}}-{{field.key}}">{{field.label}}</label>
              <text class="field-hint">{{field.hint}}</text>
            </view>
            <view class="field-control">
              <input
                id="input-{{activeJob.id}}-{{field.key}}"
                class="field-input mono-data"
                type="digit"
                inputmode="decimal"
                value="{{field.value}}"
                placeholder="{{field.placeholder}}"
                placeholder-style="color:#66748A;font-weight:500"
                maxlength="16"
                cursor-spacing="250"
                data-job-id="{{activeJob.id}}"
                data-key="{{field.key}}"
                bindinput="onInput"
                bindblur="onBlur"
                aria-label="{{activeJob.title}}{{field.label}}，单位{{field.suffix}}"
                aria-invalid="{{field.error ? 'true' : 'false'}}"
                aria-describedby="{{field.error ? 'error-' + activeJob.id + '-' + field.key : ''}}"
              />
              <text class="field-suffix">{{field.suffix}}</text>
              <button
                wx:if="{{field.value}}"
                class="clear-field-button"
                data-job-id="{{activeJob.id}}"
                data-key="{{field.key}}"
                bindtap="clearField"
                hover-class="clear-field-button-active"
                aria-label="清除{{field.label}}"
              >×</button>
            </view>
          </view>
          <text
            wx:if="{{field.error}}"
            id="error-{{activeJob.id}}-{{field.key}}"
            class="field-error"
            role="alert"
          >{{field.error}}</text>
        </view>
      </view>
    </view>

    <view class="field-group benefit-group">
      <view class="benefit-section {{showBenefits ? 'benefit-section-open' : ''}}">
        <view
          class="benefit-toggle"
          bindtap="toggleBenefits"
          hover-class="benefit-toggle-active"
          role="button"
          tabindex="0"
          aria-expanded="{{showBenefits ? 'true' : 'false'}}"
        >
          <text class="benefit-title">五险一金</text>
          <view class="benefit-toggle-meta">
            <text class="benefit-state">{{activeBenefitFilledCount ? '已填 ' + activeBenefitFilledCount + ' 项' : '可选'}}</text>
            <text class="benefit-chevron {{showBenefits ? 'benefit-chevron-open' : ''}}" aria-hidden="true">›</text>
          </view>
        </view>

        <view wx:if="{{showBenefits}}" class="benefit-content">
          <text class="benefit-copy">公司公积金计入综合价值，不算税前现金</text>
          <view
            wx:for="{{activeBenefitFields}}"
            wx:key="key"
            wx:for-item="field"
            id="field-{{activeJob.id}}-{{field.key}}"
            class="field-row {{field.error ? 'field-row-error' : ''}}"
          >
            <view class="field-main">
              <view class="field-copy">
                <label class="field-label" for="input-{{activeJob.id}}-{{field.key}}">{{field.label}}</label>
                <text class="field-hint">{{field.hint}}</text>
              </view>
              <view class="field-control">
                <input
                  id="input-{{activeJob.id}}-{{field.key}}"
                  class="field-input mono-data {{field.money ? 'field-input-money' : ''}}"
                  type="digit"
                  inputmode="decimal"
                  value="{{field.value}}"
                  placeholder="{{field.placeholder}}"
                  placeholder-style="color:#66748A;font-weight:500"
                  maxlength="16"
                  cursor-spacing="250"
                  data-job-id="{{activeJob.id}}"
                  data-key="{{field.key}}"
                  bindinput="onInput"
                  bindblur="onBlur"
                  aria-label="{{activeJob.title}}{{field.label}}，单位{{field.suffix}}"
                  aria-invalid="{{field.error ? 'true' : 'false'}}"
                  aria-describedby="{{field.error ? 'error-' + activeJob.id + '-' + field.key : ''}}"
                />
                <text class="field-suffix">{{field.suffix}}</text>
                <button
                  wx:if="{{field.value}}"
                  class="clear-field-button"
                  data-job-id="{{activeJob.id}}"
                  data-key="{{field.key}}"
                  bindtap="clearField"
                  hover-class="clear-field-button-active"
                  aria-label="清除{{field.label}}"
                >×</button>
              </view>
            </view>
            <text
              wx:if="{{field.error}}"
              id="error-{{activeJob.id}}-{{field.key}}"
              class="field-error"
              role="alert"
            >{{field.error}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{undoOfferVisible}}" class="undo-banner" role="status" aria-live="polite">
    <text>已移除 Offer B</text>
    <button class="undo-button" bindtap="undoRemoveOffer" hover-class="undo-button-active">撤销</button>
  </view>

  <view class="guide-section">
    <button
      class="guide-toggle"
      bindtap="toggleGuide"
      hover-class="guide-toggle-active"
      aria-expanded="{{showGuide ? 'true' : 'false'}}"
    >
      <text>查看计算口径</text>
      <text aria-hidden="true">{{showGuide ? '−' : '＋'}}</text>
    </button>
    <view wx:if="{{showGuide}}" class="guide-content">
      <text>保证年收入 = 月薪 ×（固定发薪月数 + 保证奖金月数）。</text>
      <text>年综合价值 = 保证年收入 + 公司公积金年缴存。</text>
      <text>综合时薪按每年工作 48 周、通勤 240 天并计入往返时间估算。</text>
      <text>公司公积金年缴存 = 缴存基数 × 公司比例 × 12；公司五险暂不折算金额。</text>
    </view>
  </view>
  <button class="clear-data-button" bindtap="clearLocalData" hover-class="clear-data-button-active">清除本机数据</button>

  <view class="submit-bar">
    <view class="submit-bar-inner">
      <view class="preview-card" aria-label="{{activeJob.title}}实时估算">
        <view class="preview-item">
          <text class="preview-label">综合价值</text>
          <text class="preview-value mono-data">{{activePreview.annualText}}</text>
        </view>
        <view class="preview-divider" aria-hidden="true"></view>
        <view class="preview-item">
          <text class="preview-label">综合时薪</text>
          <text class="preview-value mono-data">{{activePreview.hourlyText}}</text>
        </view>
      </view>
      <view class="submit-actions">
        <button
          wx:if="{{activeJobIndex > 0}}"
          class="back-step-button"
          bindtap="previousJob"
          hover-class="back-step-button-active"
        >上一步</button>
        <button
          class="submit-button"
          bindtap="advance"
          hover-class="submit-button-active"
          loading="{{isSubmitting}}"
          disabled="{{isSubmitting}}"
          aria-busy="{{isSubmitting ? 'true' : 'false'}}"
        >{{isSubmitting ? '正在计算' : primaryActionText}}</button>
      </view>
    </view>
  </view>
</view>
