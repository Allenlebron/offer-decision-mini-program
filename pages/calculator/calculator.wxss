.calculator-page {
  box-sizing: border-box;
  max-width: 560px;
  padding: 14px 16px calc(112px + env(safe-area-inset-bottom));
  margin: 0 auto;
  background: var(--surface-light);
  color: var(--text-primary);
}

.page-toolbar,
.local-badge,
.job-switcher,
.job-tab,
.entry-note,
.field-main,
.field-control,
.group-title,
.undo-banner,
.guide-toggle,
.preview-card,
.submit-actions,
.submit-bar-inner {
  display: flex;
  align-items: center;
}

.page-toolbar,
.field-main,
.undo-banner,
.guide-toggle {
  justify-content: space-between;
}

.page-toolbar {
  min-height: 44px;
}

.local-badge {
  color: var(--text-secondary);
  font-size: 12px;
  font-weight: 600;
}

.example-button,
.remove-button,
.undo-button,
.clear-data-button {
  width: auto;
  min-width: 44px;
  min-height: 44px;
  padding: 0 4px;
  margin: 0;
  background: transparent;
  color: var(--accent-strong);
  font-size: 14px;
  font-weight: 600;
  line-height: 44px;
}

.text-button-active,
.remove-button-active,
.undo-button-active {
  opacity: 0.62;
}

.job-switcher {
  gap: 4px;
  padding: 4px;
  margin-top: 10px;
  border-radius: 12px;
  background: var(--surface-muted);
}

.job-tab {
  width: auto;
  min-width: 0;
  min-height: 44px;
  flex: 1;
  gap: 4px;
  justify-content: center;
  padding: 0 5px;
  margin: 0;
  border-radius: 8px;
  background: transparent;
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 600;
  line-height: 1.2;
}

.job-tab-selected {
  background: var(--accent);
  color: var(--text-on-dark);
}

.job-tab-active,
.submit-button-active,
.back-step-button-active {
  transform: scale(0.985);
}

.job-tab-check {
  color: currentColor;
  font-size: 13px;
}

.job-tab-count {
  color: var(--text-secondary);
  font-size: 12px;
}

.job-tab-selected .job-tab-count {
  color: var(--text-on-dark);
}

.add-job-tab {
  white-space: nowrap;
}

.entry-note {
  min-height: 46px;
  gap: 7px;
  color: var(--text-secondary);
  font-size: 13px;
  line-height: 1.45;
}

.entry-note > text {
  min-width: 0;
  flex: 1;
}

.info-mark {
  display: flex;
  width: 18px;
  height: 18px;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--accent);
  border-radius: 50%;
  color: var(--accent-strong);
  font-size: 12px;
  font-weight: 700;
  line-height: 1;
}

.form-alert {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 10px 12px;
  margin-bottom: 12px;
  border: 1px solid var(--border-error);
  border-radius: 10px;
  background: var(--surface-error);
  color: var(--danger);
  font-size: 13px;
}

.form-alert-title {
  font-weight: 700;
}

.field-group + .field-group {
  margin-top: 22px;
}

.group-title {
  margin-bottom: 8px;
  color: var(--text-primary);
  font-size: 17px;
  font-weight: 650;
}

.field-card {
  overflow: hidden;
  border: 1px solid var(--border-light);
  border-radius: 12px;
  background: var(--surface-raised);
}

.field-row {
  padding: 13px 12px 11px;
  border-top: 1px solid var(--surface-muted);
}

.field-row:first-child {
  border-top: 0;
}

.field-main {
  min-height: 44px;
  gap: 10px;
}

.field-copy {
  min-width: 95px;
  flex: 1;
}

.field-label,
.field-hint {
  display: block;
}

.field-label {
  color: var(--text-primary);
  font-size: 14px;
  font-weight: 650;
}

.field-hint {
  margin-top: 2px;
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.35;
}

.field-control {
  min-width: 150px;
  flex: 0 1 170px;
  gap: 4px;
  justify-content: flex-end;
}

.field-prefix,
.field-suffix {
  flex: 0 0 auto;
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 600;
}

.field-input {
  width: 72px;
  min-width: 0;
  height: 44px;
  padding: 0;
  color: var(--text-primary);
  font-size: 16px;
  font-weight: 650;
  line-height: 44px;
  text-align: right;
}

.field-input-salary {
  width: 104px;
}

.field-input-money {
  width: 96px;
}

.field-input:focus {
  color: var(--accent-strong);
}

.clear-field-button {
  display: flex;
  width: 44px;
  min-width: 44px;
  height: 44px;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0 -6px 0 0;
  background: transparent;
  color: var(--text-secondary);
  font-size: 20px;
  font-weight: 400;
  line-height: 44px;
}

.clear-field-button-active {
  color: var(--accent);
}

.field-error {
  display: block;
  margin-top: 6px;
  color: var(--danger);
  font-size: 13px;
  font-weight: 600;
}

.field-row-error {
  background: var(--surface-error-soft);
}

.field-row-error .field-input {
  color: var(--danger);
}

.benefit-section {
  overflow: hidden;
  border: 1px solid var(--border-light);
  border-radius: 12px;
  background: var(--surface-raised);
}

.benefit-toggle {
  box-sizing: border-box;
  display: flex;
  width: 100%;
  min-height: 52px;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 0 12px;
  margin: 0;
  background: transparent;
  color: var(--text-primary);
  line-height: 1.2;
  text-align: left;
}

.benefit-section-open .benefit-toggle {
  border-bottom: 1px solid var(--surface-muted);
}

.benefit-toggle-active {
  background: var(--surface-light);
}

.benefit-copy {
  display: block;
}

.benefit-title {
  display: block;
  min-width: 0;
  flex: 1;
  font-size: 17px;
  font-weight: 650;
  line-height: 1.35;
  text-align: left;
  white-space: nowrap;
}

.benefit-copy {
  padding: 9px 12px;
  background: var(--surface-light);
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.5;
}

.benefit-toggle-meta {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 8px;
}

.benefit-state {
  color: var(--text-secondary);
  font-size: 12px;
  font-weight: 600;
}

.benefit-chevron {
  width: 24px;
  color: var(--text-secondary);
  font-size: 22px;
  font-weight: 400;
  line-height: 1;
  text-align: center;
  transform: rotate(0deg);
}

.benefit-chevron-open {
  transform: rotate(90deg);
}

.undo-banner {
  min-height: 44px;
  padding: 0 12px;
  margin-top: 12px;
  border: 1px solid var(--border-light);
  border-radius: 10px;
  background: var(--surface-raised);
  color: var(--text-secondary);
  font-size: 13px;
}

.guide-section {
  margin-top: 18px;
  border-top: 1px solid var(--border-light);
  border-bottom: 1px solid var(--border-light);
}

.guide-toggle {
  width: 100%;
  min-height: 50px;
  padding: 0;
  margin: 0;
  background: transparent;
  color: var(--text-secondary);
  font-size: 14px;
  font-weight: 600;
  text-align: left;
}

.guide-toggle-active {
  color: var(--accent-strong);
}

.guide-content {
  padding: 0 0 12px;
}

.guide-content text {
  display: block;
  color: var(--text-secondary);
  font-size: 13px;
  line-height: 1.65;
}

.guide-content text + text {
  margin-top: 5px;
}

.clear-data-button {
  display: block;
  margin: 8px auto 0;
  color: var(--text-secondary);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.clear-data-button-active {
  color: var(--danger);
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  padding: 7px 14px calc(8px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--border-light);
  background: var(--surface-raised);
}

.submit-bar-inner {
  width: 100%;
  max-width: 560px;
  flex-direction: column;
  gap: 6px;
  margin: 0 auto;
}

.preview-card {
  width: 100%;
  min-width: 0;
  min-height: 20px;
  flex: 0 0 auto;
  justify-content: center;
  gap: 12px;
  background: transparent;
}

.preview-item {
  min-width: 0;
  display: flex;
  flex: 0 1 auto;
  align-items: baseline;
  gap: 5px;
  padding: 0;
}

.preview-label,
.preview-value {
  display: block;
}

.preview-label {
  color: var(--text-secondary);
  font-size: 12px;
  font-weight: 600;
}

.preview-value {
  color: var(--accent-strong);
  font-size: 13px;
  font-weight: 700;
  line-height: 1.25;
  white-space: nowrap;
}

.preview-divider {
  width: 1px;
  height: 12px;
  background: var(--border-light);
}

.submit-actions {
  width: 100%;
  min-width: 0;
  gap: 8px;
}

.back-step-button,
.submit-button {
  box-sizing: border-box;
  width: auto;
  min-height: 52px;
  padding: 0 16px;
  margin: 0;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 650;
  line-height: 52px;
  white-space: nowrap;
}

.back-step-button {
  flex: 0 0 84px;
  border: 0;
  background: var(--surface-muted);
  color: var(--text-primary);
}

.back-step-button-active {
  background: var(--border-light);
}

.submit-button {
  width: 0;
  min-width: 0;
  flex: 1 1 0;
  background: var(--accent);
  color: var(--text-on-dark);
}

.submit-button[disabled] {
  opacity: 0.58;
}

@media (max-width: 360px) {
  .calculator-page {
    padding-right: 12px;
    padding-left: 12px;
  }

  .submit-bar {
    padding-right: 12px;
    padding-left: 12px;
  }

  .field-copy {
    min-width: 86px;
  }

  .field-control {
    min-width: 142px;
  }

  .field-input {
    width: 64px;
  }

  .field-input-salary {
    width: 96px;
  }

  .field-input-money {
    width: 84px;
  }

  .benefit-content .field-copy {
    min-width: 96px;
  }

  .benefit-content .field-label {
    font-size: 13px;
    white-space: nowrap;
  }

  .benefit-toggle {
    gap: 8px;
  }

  .job-tab {
    padding-right: 3px;
    padding-left: 3px;
  }
}
