<view class="page-shell result-page">
  <view wx:if="{{empty}}" class="empty-state">
    <text class="empty-kicker">暂无结果</text>
    <view class="empty-title" role="heading" aria-level="1">先完成一次对比</view>
    <text class="empty-copy">填入两份工作的收入和时间，即可查看结果。</text>
    <button class="primary-button" bindtap="backToCalculator" hover-class="primary-button-active">开始填写</button>
  </view>

  <block wx:else>
    <view class="result-content">
      <view class="result-hero">
        <view class="privacy-row">
          <view class="privacy-badge">本机保存 · 不上传</view>
          <text class="result-index mono-data">{{resultCards.length}} 份数据</text>
        </view>
        <text class="result-kicker">{{comparisonTitle}}</text>
        <view class="result-title" role="heading" aria-level="1">{{summaryTitle}}</view>
        <text class="result-note">保证收入与时间回报按同一口径计算。</text>
      </view>

      <view class="comparison-table result-count-{{resultCards.length}}" aria-label="{{comparisonTitle}}数据表">
        <view class="table-row table-header-row">
          <view class="table-label-cell"></view>
          <view
            wx:for="{{resultCards}}"
            wx:key="id"
            wx:for-item="card"
            class="table-data-cell table-header-cell column-{{card.id}}"
          >
            <text class="column-title">{{card.title}}</text>
            <text wx:if="{{card.annualLeader}}" class="leader-tag leader-tag-annual">收入领先</text>
            <text wx:if="{{card.hourlyLeader}}" class="leader-tag leader-tag-hourly">时薪领先</text>
          </view>
        </view>

        <view
          wx:for="{{comparisonRows}}"
          wx:key="metric"
          wx:for-item="row"
          class="table-row metric-row-{{row.metric}}"
        >
          <view class="table-label-cell">{{row.label}}</view>
          <view
            wx:for="{{row.cells}}"
            wx:key="id"
            wx:for-item="cell"
            class="table-data-cell mono-data column-{{cell.id}} {{cell.highlighted ? 'table-value-leading' : ''}}"
            aria-label="{{cell.a11yLabel}}"
          >{{cell.value}}</view>
        </view>
      </view>

      <view class="insight-section">
        <text class="section-title">相比当前工作</text>
        <view class="insight-list">
          <view wx:for="{{insightRows}}" wx:key="id" wx:for-item="insight" class="insight-row">
            <text class="insight-label-wrap">{{insight.label}}</text>
            <text class="insight-value insight-value-{{insight.tone}} mono-data">{{insight.value}}</text>
          </view>
        </view>
      </view>

      <button
        wx:if="{{hasBreakEven}}"
        class="break-even-button"
        bindtap="openBreakEven"
        hover-class="break-even-button-active"
      >
        <text>查看关键反超条件</text>
        <text aria-hidden="true">›</text>
      </button>

      <view class="result-footer">
        <text>按 48 个工作周、240 个通勤日和税前收入估算。</text>
        <text>未计个税、五险一金及浮动收入。</text>
        <button class="clear-button" bindtap="clearLocalData" hover-class="clear-button-active">清除本机数据</button>
      </view>
    </view>

    <view class="result-action-bar">
      <view class="result-action-inner">
        <button class="edit-button" bindtap="editConditions" hover-class="edit-button-active">修改条件</button>
        <button class="share-button" open-type="share" hover-class="share-button-active">分享给朋友</button>
      </view>
    </view>
  </block>
</view>
