.result-page {
  min-height: 100vh;
  background: var(--surface-dark);
  color: var(--text-on-dark);
}

.result-content {
  box-sizing: border-box;
  max-width: 560px;
  padding: 17px 16px calc(98px + env(safe-area-inset-bottom));
  margin: 0 auto;
}

.privacy-row,
.privacy-badge,
.table-row,
.table-header-cell,
.insight-row,
.break-even-button,
.result-action-inner {
  display: flex;
  align-items: center;
}

.privacy-row,
.insight-row,
.break-even-button {
  justify-content: space-between;
}

.privacy-badge,
.result-index {
  color: var(--text-muted-dark);
  font-size: 12px;
  font-weight: 600;
}

.result-kicker {
  display: block;
  margin-top: 24px;
  color: var(--accent-secondary);
  font-size: 13px;
  font-weight: 650;
}

.result-title {
  max-width: 520px;
  margin-top: 7px;
  color: var(--text-on-dark);
  font-size: 28px;
  font-weight: 650;
  letter-spacing: -0.02em;
  line-height: 1.24;
  overflow-wrap: break-word;
}

.result-note {
  display: block;
  margin-top: 8px;
  color: var(--text-muted-dark);
  font-size: 13px;
}

.comparison-table {
  overflow: hidden;
  margin-top: 22px;
  border: 1px solid var(--border-dark);
  border-radius: 12px;
  background: var(--surface-panel);
}

.table-row {
  min-height: 54px;
  border-top: 1px solid var(--border-dark);
}

.table-row:first-child {
  border-top: 0;
}

.table-header-row {
  min-height: 76px;
}

.table-label-cell {
  box-sizing: border-box;
  width: 76px;
  flex: 0 0 76px;
  padding: 0 8px;
  color: var(--text-muted-dark);
  font-size: 12px;
  line-height: 1.3;
}

.table-data-cell {
  align-self: stretch;
  display: flex;
  min-width: 0;
  flex: 1;
  align-items: center;
  justify-content: center;
  padding: 7px 4px;
  border-left: 1px solid var(--border-dark);
  color: var(--text-on-dark);
  font-size: 13px;
  font-weight: 650;
  line-height: 1.25;
  text-align: center;
  overflow-wrap: anywhere;
}

.table-header-cell {
  align-self: stretch;
  flex-direction: column;
  gap: 3px;
  justify-content: center;
}

.column-title {
  color: var(--text-on-dark);
  font-size: 13px;
  font-weight: 650;
}

.leader-tag {
  padding: 2px 5px;
  border-radius: 5px;
  font-size: 12px;
  font-weight: 700;
  line-height: 1.25;
}

.leader-tag-annual {
  background: var(--attention);
  color: var(--attention-text);
}

.leader-tag-hourly {
  background: var(--accent-secondary);
  color: var(--surface-dark);
}

.metric-row-annual .table-value-leading {
  color: var(--attention);
}

.metric-row-hourly .table-value-leading {
  color: var(--accent-secondary);
}

.benefit-comparison-section {
  margin-top: 22px;
}

.benefit-note {
  display: block;
  margin-top: 5px;
  color: var(--text-muted-dark);
  font-size: 12px;
  line-height: 1.5;
}

.benefit-comparison-table {
  margin-top: 9px;
}

.benefit-header-row {
  min-height: 54px;
}

.insight-section {
  margin-top: 22px;
}

.section-title {
  color: var(--text-on-dark);
  font-size: 16px;
  font-weight: 650;
}

.insight-list {
  overflow: hidden;
  margin-top: 8px;
  border-top: 1px solid var(--border-dark);
  border-bottom: 1px solid var(--border-dark);
}

.insight-row {
  min-height: 48px;
  gap: 12px;
  border-top: 1px solid var(--border-dark);
  color: var(--text-muted-dark);
  font-size: 14px;
}

.insight-row:first-child {
  border-top: 0;
}

.insight-label-wrap {
  min-width: 0;
}

.insight-value {
  flex: 0 0 auto;
  font-size: 14px;
  font-weight: 700;
}

.insight-value-blue {
  color: var(--accent-secondary);
}

.insight-value-amber {
  color: var(--attention);
}

.break-even-button {
  width: 100%;
  min-height: 52px;
  gap: 10px;
  padding: 0 14px;
  margin: 20px 0 0;
  border-radius: 8px;
  background: var(--accent);
  color: var(--text-on-dark);
  font-size: 15px;
  font-weight: 650;
}

.break-even-button > text:last-child {
  font-size: 22px;
  font-weight: 400;
}

.break-even-button-active,
.edit-button-active,
.share-button-active,
.primary-button-active {
  transform: scale(0.985);
}

.result-footer {
  padding-top: 20px;
  color: var(--text-muted-dark);
  font-size: 12px;
  line-height: 1.65;
}

.result-footer > text {
  display: block;
}

.clear-button {
  width: auto;
  min-height: 44px;
  padding: 0;
  margin: 6px 0 0;
  background: transparent;
  color: var(--text-muted-dark);
  font-size: 13px;
  line-height: 44px;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.clear-button-active {
  color: var(--danger-on-dark);
}

.result-action-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  padding: 7px 14px calc(8px + env(safe-area-inset-bottom));
  border-top: 1px solid var(--border-dark);
  background: var(--surface-dark);
}

.result-action-inner {
  width: 100%;
  max-width: 560px;
  gap: 6px;
  margin: 0 auto;
}

.edit-button,
.share-button,
.primary-button {
  min-height: 52px;
  padding: 0 10px;
  margin: 0;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 650;
  line-height: 52px;
}

.edit-button {
  width: 42%;
  border: 1px solid var(--accent-secondary);
  background: transparent;
  color: var(--accent-secondary);
}

.share-button {
  min-width: 0;
  flex: 1;
  background: var(--accent);
  color: var(--text-on-dark);
}

.empty-state {
  box-sizing: border-box;
  display: flex;
  min-height: 82vh;
  max-width: 560px;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 24px 16px;
  margin: 0 auto;
}

.empty-kicker {
  color: var(--accent-secondary);
  font-size: 13px;
  font-weight: 650;
}

.empty-title {
  margin-top: 8px;
  color: var(--text-on-dark);
  font-size: 28px;
  font-weight: 650;
}

.empty-copy {
  margin-top: 7px;
  color: var(--text-muted-dark);
  font-size: 14px;
  line-height: 1.6;
}

.primary-button {
  min-width: 140px;
  margin-top: 15px;
  background: var(--accent);
  color: var(--text-on-dark);
}

@media (max-width: 360px) {
  .result-content {
    padding-right: 12px;
    padding-left: 12px;
  }

  .table-label-cell {
    width: 66px;
    flex-basis: 66px;
    padding-right: 5px;
    padding-left: 5px;
  }

  .table-data-cell {
    padding-right: 2px;
    padding-left: 2px;
  }
}
