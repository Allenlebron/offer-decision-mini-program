.result-page {
  max-width: 560px;
  margin: 0 auto;
}

.empty-state {
  display: flex;
  min-height: 80vh;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 24rpx;
  padding: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.empty-title,
.result-headline,
.break-even-title,
.feedback-title {
  font-family: "Songti SC", STSong, serif;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.empty-title {
  font-size: 48rpx;
  line-height: 1.2;
}

.empty-copy {
  color: #415149;
  line-height: 1.7;
}

.primary-button,
.share-button,
.recalculate-button,
.feedback-button,
.receipt-button {
  min-height: 52px;
  border-radius: 8rpx;
  font-weight: 700;
}

.primary-button {
  min-width: 320rpx;
  margin: 16rpx 0 0;
  background: #13221c;
  color: #fbfcf8;
}

.primary-button-active,
.receipt-button-active {
  background: #254237;
}

.result-hero {
  padding: 48rpx 32rpx;
  background: #13221c;
  color: #fbfcf8;
}

.result-step {
  color: #d7f55f;
}

.result-headline {
  margin-top: 24rpx;
  font-size: 48rpx;
  line-height: 1.22;
}

.result-caveat {
  display: block;
  margin-top: 24rpx;
  color: rgba(251, 252, 248, 0.76);
  font-size: 28rpx;
  line-height: 1.7;
}

.result-list {
  padding: 0 32rpx;
  background: #13221c;
  color: #fbfcf8;
}

.result-option {
  padding: 32rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.22);
}

.result-option-header,
.result-option-title,
.leader-row,
.metric-row,
.chart-label-row,
.chart-name,
.result-actions,
.feedback-grid,
.footer-brand {
  display: flex;
  align-items: center;
}

.result-option-header,
.metric-row,
.chart-label-row {
  justify-content: space-between;
}

.result-option-title,
.chart-name {
  gap: 16rpx;
  font-weight: 700;
}

.result-option-title {
  font-size: 38rpx;
  line-height: 1.35;
}

.option-dot {
  width: 20rpx;
  height: 20rpx;
  flex: 0 0 auto;
  border-radius: 50%;
}

.option-dot.small {
  width: 16rpx;
  height: 16rpx;
}

.result-delta {
  color: #d7f55f;
  font-size: 28rpx;
  font-weight: 700;
}

.leader-row {
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.leader-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(215, 245, 95, 0.14);
  color: #d7f55f;
  font-size: 26rpx;
  font-weight: 700;
}

.metric-row {
  min-height: 92rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(251, 252, 248, 0.74);
}

.time-summary {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 8rpx 24rpx;
  padding-top: 24rpx;
  color: rgba(251, 252, 248, 0.74);
  font-size: 28rpx;
}

.time-summary .mono-data {
  color: #fbfcf8;
  font-weight: 700;
}

.metric-row:first-of-type {
  margin-top: 24rpx;
}

.metric-value {
  color: #fbfcf8;
  font-size: 34rpx;
  font-weight: 700;
}

.hourly-delta {
  display: block;
  margin-top: 16rpx;
  color: rgba(251, 252, 248, 0.78);
  font-size: 28rpx;
}

.comparison-section {
  padding: 48rpx 32rpx;
}

.comparison-block + .comparison-block {
  margin-top: 48rpx;
}

.comparison-title {
  display: block;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #13221c;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
}

.chart-row {
  margin-top: 24rpx;
}

.chart-label-row {
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.chart-track {
  height: 20rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e8ebe6;
}

.chart-fill {
  height: 100%;
  border-radius: inherit;
}

.break-even {
  padding: 48rpx 32rpx;
  border-top: 2rpx solid #13221c;
  border-bottom: 2rpx solid #13221c;
  background: #fff0ea;
}

.break-even-label {
  color: #8d2618;
  font-size: 28rpx;
  font-weight: 700;
}

.break-even-title {
  margin-top: 16rpx;
  font-size: 40rpx;
  line-height: 1.45;
}

.break-even-number {
  color: #8d2618;
  font-weight: 700;
}

.break-even-help {
  display: block;
  margin-top: 16rpx;
  color: #415149;
  font-size: 28rpx;
  line-height: 1.65;
}

.result-actions {
  flex-direction: column;
  gap: 16rpx;
  padding: 32rpx;
  background: #13221c;
}

.share-button,
.recalculate-button {
  width: 100%;
}

.share-button {
  background: #d7f55f;
  color: #13221c;
}

.share-button-active,
.feedback-button-active {
  background: #c8e74d;
}

.recalculate-button {
  border: 2rpx solid rgba(255, 255, 255, 0.34);
  background: transparent;
  color: #fbfcf8;
}

.recalculate-button-active {
  background: rgba(255, 255, 255, 0.08);
}

.feedback-section {
  padding: 48rpx 32rpx;
}

.feedback-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  line-height: 1.2;
}

.feedback-copy {
  display: block;
  margin-top: 16rpx;
  color: #415149;
  line-height: 1.65;
}

.feedback-grid {
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
}

.feedback-button {
  width: calc(50% - 8rpx);
  border: 2rpx solid #13221c;
  background: transparent;
  color: #13221c;
}

.feedback-button-selected {
  border-color: #8d2618;
  background: #d7f55f;
  box-shadow: inset 0 0 0 4rpx #f5f6f2, inset 0 0 0 6rpx #8d2618;
}

.receipt-button {
  width: 100%;
  margin-top: 16rpx;
  background: #13221c;
  color: #fbfcf8;
}

.receipt-button[disabled] {
  opacity: 0.68;
}

.receipt-status {
  display: block;
  min-height: 48rpx;
  margin-top: 16rpx;
  color: #415149;
  font-size: 28rpx;
  text-align: center;
}

.result-footer {
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid rgba(19, 34, 28, 0.16);
}

.footer-brand {
  gap: 16rpx;
}

.brand-mark.small {
  width: 64rpx;
  height: 64rpx;
  font-size: 30rpx;
}

.footer-title,
.footer-copy {
  display: block;
}

.footer-title {
  font-weight: 700;
}

.footer-copy {
  color: #415149;
  font-size: 26rpx;
}

.clear-button {
  min-height: 44px;
  padding: 0;
  margin: 32rpx auto 0;
  background: transparent;
  color: #415149;
  font-size: 28rpx;
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

.clear-button-active {
  color: #8d2618;
}

@media (max-width: 360px) {
  .result-headline {
    font-size: 44rpx;
  }

  .result-option-header {
    align-items: flex-start;
    flex-direction: column;
    gap: 16rpx;
  }

  .feedback-button {
    width: 100%;
  }
}
